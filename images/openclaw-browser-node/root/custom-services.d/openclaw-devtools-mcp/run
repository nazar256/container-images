#!/usr/bin/with-contenv bash
set -euo pipefail

runtime_user="${OPENCLAW_RUNTIME_USER:-abc}"
browser_cdp_url="${OPENCLAW_BROWSER_CDP_URL:-http://127.0.0.1:${CDP_PORT:-9222}}"
mcp_host="${OPENCLAW_DEVTOOLS_MCP_HOST:-127.0.0.1}"
mcp_port="${OPENCLAW_DEVTOOLS_MCP_PORT:-9223}"
mcp_path="${OPENCLAW_DEVTOOLS_MCP_PATH:-/mcp}"
cdp_wait_timeout="${OPENCLAW_DEVTOOLS_MCP_CDP_WAIT_TIMEOUT:-60}"
cdp_wait_interval="${OPENCLAW_DEVTOOLS_MCP_CDP_WAIT_INTERVAL:-2}"

is_true() {
  case "${1,,}" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}

if ! is_true "${OPENCLAW_DEVTOOLS_MCP_ENABLED:-true}"; then
  echo "[openclaw-devtools-mcp] disabled; keeping service idle"
  exec s6-setuidgid "${runtime_user}" sleep infinity
fi

if ! [[ "${cdp_wait_timeout}" =~ ^[0-9]+$ ]] || [ "${cdp_wait_timeout}" -le 0 ]; then
  echo "[openclaw-devtools-mcp] OPENCLAW_DEVTOOLS_MCP_CDP_WAIT_TIMEOUT must be a positive integer number of seconds; got '${cdp_wait_timeout}'" >&2
  exit 1
fi

if ! [[ "${cdp_wait_interval}" =~ ^[0-9]+$ ]] || [ "${cdp_wait_interval}" -le 0 ]; then
  echo "[openclaw-devtools-mcp] OPENCLAW_DEVTOOLS_MCP_CDP_WAIT_INTERVAL must be a positive integer number of seconds; got '${cdp_wait_interval}'" >&2
  exit 1
fi

if is_true "${OPENCLAW_DEVTOOLS_MCP_DISABLE_USAGE_STATISTICS:-true}"; then
  export CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS=1
fi

if is_true "${OPENCLAW_DEVTOOLS_MCP_DISABLE_UPDATE_CHECKS:-true}"; then
  export CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS=1
fi

cdp_wait_deadline=$((SECONDS + cdp_wait_timeout))

echo "[openclaw-devtools-mcp] waiting for browser CDP at ${browser_cdp_url} (timeout: ${cdp_wait_timeout}s, interval: ${cdp_wait_interval}s)"
until curl --silent --show-error --fail --max-time 2 "${browser_cdp_url}/json/version" >/dev/null; do
  if [ "${SECONDS}" -ge "${cdp_wait_deadline}" ]; then
    echo "[openclaw-devtools-mcp] timed out after ${cdp_wait_timeout}s waiting for browser CDP at ${browser_cdp_url}; ensure Chromium is running and exposes /json/version (for example, check remote-debugging flags or CHROME_CLI overrides)" >&2
    exit 1
  fi

  remaining=$((cdp_wait_deadline - SECONDS))
  sleep_for="${cdp_wait_interval}"
  if [ "${remaining}" -lt "${sleep_for}" ]; then
    sleep_for="${remaining}"
  fi

  echo "[openclaw-devtools-mcp] browser CDP not ready yet; retrying in ${sleep_for}s (${remaining}s remaining)"
  sleep "${sleep_for}"
done

echo "[openclaw-devtools-mcp] starting Streamable HTTP MCP endpoint on ${mcp_host}:${mcp_port}${mcp_path}"
exec s6-setuidgid "${runtime_user}" \
  node /usr/local/lib/openclaw-devtools-mcp/index.mjs
